NODE_ENV=development
PORT=3000
ALLOWED_ORIGINS=http://localhost:5173

OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
# Example guest->host address on Hyper-V: http://172.18.144.1:11434

DEFAULT_PROVIDER=openrouter
DEFAULT_MODEL=openai/gpt-4o-mini
FALLBACK_PROVIDER=openrouter
FALLBACK_MODEL=meta-llama/llama-3.1-8b-instruct
MODEL_ALLOWLIST=
ADMIN_PASSWORD=

PLAYFUL_MODE_ENABLED=true

DAILY_BUDGET_USD=3
WARNING_BUDGET_PERCENT=80
REQUEST_MAX_INPUT_CHARS=4000
REQUEST_MAX_OUTPUT_TOKENS=400
MIN_TEXT_THRESHOLD=20
PROVIDER_TIMEOUT_MS=20000
OLLAMA_TIMEOUT_MS=300000
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=600

DATABASE_URL=sqlite://./data/predict_your_thoughts.db
